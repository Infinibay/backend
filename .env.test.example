# Copy this file to .env.test and set credentials for a DEDICATED Postgres database.
# The test runner truncates EVERY user table between tests. Do not point this at
# your development database — the runner has a guard, but double-check anyway.
#
# Conventions:
# - TEST_DATABASE_URL is what tests actually read (via prisma-test-client).
# - DATABASE_URL mirrors it so Prisma CLI commands (prisma migrate, etc.) work
#   against the same DB when running with this env file.
# - Credentials here MAY differ from your dev DATABASE_URL. A typical local
#   setup has them identical, but CI or shared machines often use a separate
#   user with narrower grants on the _test database only.

TEST_DATABASE_URL="postgresql://infinibay_test_user:change-me@localhost:5432/infinibay_test?schema=public"
DATABASE_URL="${TEST_DATABASE_URL}"

# App configuration used by tests
FRONTEND_URL="*"
TOKENKEY=TEST_TOKEN
PORT=4001
RPC_URL="http://localhost:9090"

INFINIBAY_BASE_DIR=/opt/infinibay
GRAPHIC_HOST=127.0.0.1
BRIDGE_NAME=br0

# ISO directories
INFINIBAY_ISO_DIR=/opt/infinibay/iso
INFINIBAY_ISO_TEMP_DIR=/opt/infinibay/iso/temp
INFINIBAY_ISO_PERMANENT_DIR=/opt/infinibay/iso/permanent
VIRTIO_WIN_ISO_PATH=/opt/infinibay/iso/permanent/virtio-win.iso
