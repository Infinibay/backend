generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String                     @id @default(uuid())
  email                       String                     @unique
  password                    String
  deleted                     Boolean
  token                       String                     @default("null")
  firstName                   String
  lastName                    String
  createdAt                   DateTime                   @default(now())
  role                        UserRole                   @default(USER)
  updatedAt                   DateTime                   @updatedAt
  identityProviderId          String?
  externalId                  String?
  externalDn                  String?
  lastDirectorySyncAt         DateTime?
  tokenInvalidatedAt          DateTime?
  identityProvider            IdentityProvider?          @relation(fields: [identityProviderId], references: [id], onDelete: SetNull)
  VM                          Machine[]
  maintenanceHistory          MaintenanceHistory[]
  maintenanceTasks            MaintenanceTask[]
  scripts                     Script[]
  scriptExecutions            ScriptExecution[]
  departmentScriptAssignments DepartmentScript[]
  scriptAuditLogs             ScriptAuditLog[]
  approvedScripts             Script[]                   @relation("ScriptApprovals")
  recommendationResolutions   RecommendationResolution[]
  departmentMemberships       DepartmentMembership[]
  policyAuditLogs             PolicyAuditLog[]           @relation("PolicyAuditActor")
  roleId                      String?
  customRole                  Role?                      @relation(fields: [roleId], references: [id])
  permissionOverrides         UserPermissionOverride[]
  refreshTokens               RefreshToken[]

  @@unique([identityProviderId, externalId])
  @@index([identityProviderId])
  @@index([roleId])
}

// Opaque refresh tokens for session rotation. The raw token is shown to the
// client once; only its sha256 hash is stored. Rotation revokes the old row and
// issues a new one. Access-token (JWT) revocation is handled separately via
// User.tokenInvalidatedAt — any access token whose iat predates that instant is
// rejected at verification time.
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Backend-driven feature flags. Only the on/off OVERRIDE is stored here, keyed
// by the flag's stable `key`; the label/description/default live in the code
// registry (app/featureFlags/registry.ts). The featureFlags query merges the
// registry defaults with these overrides. Absent row => the registry default.
model FeatureFlag {
  key         String   @id
  enabled     Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  updatedById String?
}

model IdentityProvider {
  id                    String                     @id @default(uuid())
  name                  String                     @unique
  providerType          IdentityProviderType
  status                IdentityProviderStatus     @default(DISCONNECTED)
  enabled               Boolean                    @default(true)
  domain                String?
  host                  String
  port                  Int                        @default(389)
  useTls                Boolean                    @default(false)
  tlsCa                 String?                    @db.Text
  tlsInsecureSkipVerify Boolean                    @default(false)
  baseDn                String
  bindDn                String?
  bindPasswordSecret    String?
  userFilter            String?
  groupFilter           String?
  attributes            Json?
  lastTestAt            DateTime?
  lastSyncAt            DateTime?
  lastError             String?                    @db.Text
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  syncRuns              IdentitySyncRun[]
  users                 User[]
  groupRoleMappings     IdentityGroupRoleMapping[]
  domainJoinedMachines  MachineConfiguration[]     @relation("VMDomainProvider")

  @@index([providerType])
  @@index([status])
}

model IdentityGroupRoleMapping {
  id         String           @id @default(uuid())
  providerId String
  groupDn    String
  groupName  String
  role       UserRole
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  provider   IdentityProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, groupDn])
  @@index([providerId])
  @@index([role])
}

model IdentitySyncRun {
  id            String             @id @default(uuid())
  providerId    String
  status        IdentitySyncStatus
  startedAt     DateTime           @default(now())
  finishedAt    DateTime?
  usersCreated  Int                @default(0)
  usersUpdated  Int                @default(0)
  usersDisabled Int                @default(0)
  groupsSeen    Int                @default(0)
  message       String?
  error         String?            @db.Text
  provider      IdentityProvider   @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, startedAt])
  @@index([status])
}

// Action/verb-based RBAC. A Role is a named bundle of permission grants
// (system presets SUPER_ADMIN/ADMIN/USER + user-created custom roles). A grant
// is a `resource:verb` (or grouping `resource:manage` / `*`) at a scope.
model Role {
  id          String           @id @default(uuid())
  key         String           @unique // 'SUPER_ADMIN'|'ADMIN'|'USER' or a custom slug
  name        String
  description String?
  isSystem    Boolean          @default(false)
  priority    Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       User[]
}

model RolePermission {
  id         String          @id @default(uuid())
  roleId     String
  role       Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission String // 'vm:edit' | 'vm:manage' | '*'
  scope      PermissionScope @default(ANY)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([roleId, permission])
  @@index([roleId])
}

// Per-user grant/deny override layered on top of the user's role. DENY wins.
model UserPermissionOverride {
  id         String          @id @default(uuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission String
  scope      PermissionScope @default(ANY)
  effect     GrantEffect     @default(ALLOW)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([userId, permission])
  @@index([userId])
}

model Node {
  id              String    @id @default(uuid())
  name            String
  currentRaid     String
  nextRaid        String?
  cpuFlags        Json
  ram             Int
  cores           Int
  maintenanceMode Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  disks           Disk[]
  machines        Machine[]
}

model Disk {
  id        String   @id @default(uuid())
  path      String
  nodeId    String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  node      Node     @relation(fields: [nodeId], references: [id])
}

model ISO {
  id           String    @id @default(uuid())
  filename     String    @unique
  os           String
  version      String?
  size         BigInt
  uploadedAt   DateTime  @default(now())
  lastVerified DateTime?
  isAvailable  Boolean   @default(true)
  checksum     String?
  downloadUrl  String?
  path         String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Machine {
  id                 String                @id @default(uuid())
  name               String
  internalName       String
  /// QEMU process state. Allowed values: off | starting | running | suspended | paused | updating_hardware | powering_off_update | rebuilding | error.
  /// 'rebuilding' is a transient lock set while a non-persistent pool desktop is re-baselined to its golden image (see NonPersistentResetService).
  /// Independent from MachineConfiguration.setupComplete (whether OS install + first infiniservice handshake completed).
  status             String
  userId             String?
  templateId         String?
  os                 String
  cpuCores           Int                   @default(0)
  ramGB              Int                   @default(0)
  diskSizeGB         Int                   @default(0)
  gpuPciAddress      String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  departmentId       String?
  version            Int                   @default(1)
  nodeId             String?
  localIP            String?
  publicIP           String?
  firewallRuleSetId  String?               @unique
  applicationUsage   ApplicationUsage[]
  department         Department?           @relation(fields: [departmentId], references: [id])
  firewallRuleSet    FirewallRuleSet?      @relation(fields: [firewallRuleSetId], references: [id], onDelete: SetNull)
  node               Node?                 @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  template           MachineTemplate?      @relation(fields: [templateId], references: [id])
  user               User?                 @relation(fields: [userId], references: [id])
  poolId             String?
  pool               Pool?                 @relation(fields: [poolId], references: [id])
  applications       MachineApplication[]
  configuration      MachineConfiguration?
  maintenanceHistory MaintenanceHistory[]
  maintenanceTasks   MaintenanceTask[]
  pendingCommands    PendingCommand[]
  portUsage          PortUsage[]
  blockedConnections BlockedConnection[]
  processSnapshots   ProcessSnapshot[]
  systemEvents       SystemEvent[]
  systemMetrics      SystemMetrics[]
  healthAlerts       VMHealthAlert[]
  healthCheckQueue   VMHealthCheckQueue[]
  healthConfig       VMHealthConfig?
  healthSnapshots    VMHealthSnapshot[]
  recommendations    VMRecommendation[]
  windowsServices    WindowsService[]
  scriptExecutions   ScriptExecution[]
  agentEvents        AgentEvent[]
  backups            Backup[]
  backupSchedules    BackupSchedule[]

  @@index([nodeId])
}

/// Structured event/log entry forwarded by the in-VM agent (infiniservice).
/// Used to surface guest-side errors that previously only existed in agent logs.
model AgentEvent {
  id          String             @id @default(uuid())
  machineId   String
  severity    AgentEventSeverity
  source      String
  message     String             @db.Text
  executionId String?
  context     Json?
  /// Timestamp claimed by the agent (may differ slightly from createdAt due to drift).
  occurredAt  DateTime
  createdAt   DateTime           @default(now())
  machine     Machine            @relation(fields: [machineId], references: [id], onDelete: Cascade)
  execution   ScriptExecution?   @relation(fields: [executionId], references: [id], onDelete: SetNull)

  @@index([machineId, createdAt])
  @@index([executionId])
}

enum AgentEventSeverity {
  DEBUG
  INFO
  WARN
  ERROR
}

enum IdentityProviderType {
  ACTIVE_DIRECTORY
  LDAP
}

enum IdentityProviderStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  SYNCING
}

enum IdentitySyncStatus {
  RUNNING
  SUCCESS
  ERROR
}

// Scope axis for instance-bearing verbs. Global verbs (create/list/settings)
// ignore scope. Ordering: ANY ⊇ DEPARTMENT ⊇ OWN.
enum PermissionScope {
  OWN
  DEPARTMENT
  ANY
}

// Effect for per-user overrides only (role grants are always additive/ALLOW).
enum GrantEffect {
  ALLOW
  DENY
}

model MachineConfiguration {
  id              String   @id @default(uuid())
  xml             Json?
  graphicProtocol String?
  graphicPort     Int?
  graphicPassword String?
  graphicHost     String?
  assignedGpuBus  String?
  machineId       String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  machine         Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)

  // Infinization QEMU process management fields (nullable for backward compatibility)
  qmpSocketPath String? // Unix socket path for QMP communication
  qemuPid       Int? // QEMU process PID for health monitoring
  tapDeviceName String? // TAP network device name for cleanup

  // ============================================================================
  // QEMU CONFIGURATION FIELDS
  // ============================================================================
  // These fields configure QEMU VM parameters. All fields are nullable for
  // backward compatibility with existing VMs.
  //
  // NULL VALUE HANDLING (for consuming code like VMLifecycle, QemuCommandBuilder):
  // - A null value means "use default behavior" as specified in @default()
  // - Non-null values override the default behavior
  // - When reading these fields, apply the intended default if null:
  //     const bridge = config.bridge ?? 'virbr0';
  //     const machineType = config.machineType ?? 'q35';
  //
  // Fields with @default() get that value on INSERT, but existing rows will
  // have NULL until explicitly updated. Always handle null in consuming code.
  // ============================================================================

  // Network configuration (HIGH PRIORITY)
  // Network bridge device name (e.g., infinibr-XXXXXX) - per-department bridge.
  // Populated by machineLifecycleService from Department.bridgeName at create time.
  bridge        String?
  // NIC model for network device (virtio-net-pci provides best performance)
  networkModel  String? @default("virtio-net-pci")
  // Multi-queue networking support - number of queues for parallel packet processing
  networkQueues Int?    @default(1)

  // Machine configuration (HIGH PRIORITY)
  // QEMU machine type (q35 is modern chipset with PCIe support, i440fx for legacy)
  machineType String? @default("q35")
  // CPU model for guest (host provides best performance, or specific model for migration compatibility)
  cpuModel    String? @default("host")

  // Storage configuration (HIGH PRIORITY)
  // Disk bus type (virtio for performance, scsi/sata for compatibility)
  diskBus       String?  @default("virtio")
  // Disk cache mode: writeback (performance), writethrough (safety), none (direct I/O)
  diskCacheMode String?  @default("writeback")
  // Enable I/O threading for disk operations - offloads I/O to dedicated threads
  ioThreads     Boolean? @default(false)
  // Multi-disk support - stores array of disk paths as JSON
  // Format: ["path/to/disk1.qcow2", "path/to/disk2.qcow2"]
  // NULL or empty array means use legacy single-disk path computation
  diskPaths     Json?

  // Last error captured by backgroundCode rollback. Surfaces failure reasons
  // (e.g. "GPU bound to nvidia, not vfio-pci") to the UI instead of bare 'error'.
  lastError String?

  // GPU configuration (ADDITIONAL)
  // Path to GPU ROM file for passthrough (needed for some GPUs)
  gpuRomFile  String?
  // PCI address for GPU audio device passthrough
  gpuAudioBus String?

  // Performance features (MEDIUM PRIORITY)
  // Enable dynamic memory management via balloon device
  memoryBalloon Boolean? @default(false)
  // Use hugepages for better memory performance (requires host configuration)
  hugepages     Boolean? @default(false)

  // Advanced configuration (LOW PRIORITY)
  // NUMA topology configuration for multi-socket optimization (format: {"nodes": [...]})
  numaConfig Json?
  // CPU affinity configuration (format: {"cores": [0, 1, 2]}) - uses cgroups v2
  cpuPinning Json?

  // NUMA-aware CPU pinning via numactl process wrapper
  // When enabled, QEMU is launched with numactl to pin CPUs and memory to NUMA nodes
  enableNumaCtlPinning Boolean? @default(false)
  // Strategy for automatic CPU pinning: 'basic' (sequential) or 'hybrid' (randomized)
  cpuPinningStrategy   String?  @default("basic")

  // UEFI configuration (LOW PRIORITY)
  // Path to OVMF firmware file for UEFI boot
  uefiFirmware String?
  // Enable UEFI Secure Boot
  secureboot   Boolean? @default(false)

  // ============================================================================
  // QEMU DEVICE SOCKET PATHS
  // ============================================================================
  // These fields store socket paths for various QEMU devices and channels.
  // All fields are nullable for backward compatibility.

  // TPM 2.0 socket path for Trusted Platform Module emulation (Windows 11 requirement)
  tpmSocketPath           String?
  // QEMU Guest Agent socket for host-guest communication
  guestAgentSocketPath    String?
  // InfiniService custom channel socket for application management
  infiniServiceSocketPath String?

  // ============================================================================
  // ADDITIONAL VM CONFIGURATION
  // ============================================================================
  // VirtIO drivers ISO path for Windows VMs
  virtioDriversIso String?
  // Enable Intel HDA audio device
  enableAudio      Boolean? @default(false)
  // Enable USB tablet for absolute mouse positioning
  enableUsbTablet  Boolean? @default(true)

  // ============================================================================
  // INSTALLATION STATE TRACKING
  // ============================================================================
  // true = VM has completed initial setup (infiniservice connected for first time)
  // false/null = VM still in building/installation phase
  setupComplete Boolean? @default(false)

  // ============================================================================
  // ACTIVE DIRECTORY DOMAIN JOIN STATE
  // ============================================================================
  // Set by DomainJoinService when a VM is joined to an AD/LDAP domain via the
  // in-VM agent (JoinDomain command). All nullable for backward compatibility.
  // 'PENDING' | 'JOINED' | 'FAILED'
  domainJoinStatus         String?
  // The domain the VM was last (attempted to be) joined to, e.g. corp.example.com.
  domainName               String?
  // Timestamp of the last successful join.
  domainJoinedAt           DateTime?
  // Error message from the last failed join attempt.
  domainJoinError          String?
  // The IdentityProvider whose domain/credentials were used for the join.
  // SetNull on delete: removing a directory must not delete VM config rows nor
  // leave a dangling reference — the join state stays, the provider link clears.
  domainIdentityProviderId String?
  domainIdentityProvider   IdentityProvider? @relation("VMDomainProvider", fields: [domainIdentityProviderId], references: [id], onDelete: SetNull)

  @@index([domainIdentityProviderId])
}

model MachineTemplate {
  id            String                       @id @default(uuid())
  name          String
  description   String?
  // Canonical OS key. Required by the UI for new blueprints; nullable
  // at the DB level so rows created before this column existed keep
  // working. When set, CreateMachineService uses it as the source of
  // truth and ignores the per-VM Machine.os.
  // Values: 'windows10' | 'windows11' | 'ubuntu' | 'fedora'.
  osType        String?
  cores         Int
  /// In GB
  ram           Int
  /// In GB
  storage       Int
  createdAt     DateTime                     @default(now())
  categoryId    String?
  updatedAt     DateTime                     @updatedAt
  // Optional link to a sealed base disk image. When set, VMs instantiated
  // from this template are created as thin linked clones (qcow2 backing
  // chain) instead of being installed from an unattended ISO.
  goldenImageId String?
  // Path/URL of the desktop wallpaper image applied on first boot.
  wallpaperUrl  String?
  // Power plan token: 'balanced' | 'high-performance' | 'power-saver'.
  // Applied on first boot via a generated script; OS-specific.
  powerPlan     String?
  // Enable full-disk encryption on VMs created from this blueprint.
  // Windows: BitLocker on C: (requires TPM, auto-configured by infinization
  // for Win11; Win10 must have TPM exposed). Linux: currently NOT APPLIED —
  // LUKS requires unattended-install rework. Field persists for future use.
  encryptDisk   Boolean                      @default(false)
  machines      Machine[]
  category      MachineTemplateCategory?     @relation(fields: [categoryId], references: [id])
  goldenImage   GoldenImage?                 @relation(fields: [goldenImageId], references: [id])
  // Apps pre-installed on every VM instantiated from this blueprint.
  // These propagate to per-VM MachineApplication rows on create.
  applications  MachineTemplateApplication[]
  // Scripts executed at FIRST_BOOT on every VM. Typically hardening
  // scripts from the 'golden-image' category, but any Script works.
  scripts       MachineTemplateScript[]
  pools         Pool[]

  @@index([goldenImageId])
}

// A pool is a group of desktops sharing a blueprint + golden image +
// department + assignment policy. Covers the canonical VDI modes:
// persistent (each user has their own machine) and non-persistent
// (any idle machine, wiped on logoff). The background refill job
// keeps `current >= sizeMin` whenever capacity allows; on-demand
// spawn kicks in up to `sizeMax` when a user requests a desktop and
// none are idle. Pools are scoped to a single department to align
// with the network + firewall tenancy model.
model Pool {
  id                 String          @id @default(uuid())
  name               String
  templateId         String
  goldenImageId      String?
  departmentId       String
  // 'persistent' | 'non-persistent'
  type               String          @default("non-persistent")
  sizeMin            Int             @default(0)
  sizeMax            Int             @default(10)
  idleTimeoutMinutes Int? // null = no idle auto-stop
  // If true, a non-persistent VM is reset to golden-image state when
  // its QEMU process exits (user logoff or shutdown). Ignored on
  // persistent pools.
  resetOnLogoff      Boolean         @default(true)
  // Drain state: when true, no new connections are handed out from
  // this pool. Existing sessions keep running. The refill job stops.
  draining           Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  template           MachineTemplate @relation(fields: [templateId], references: [id])
  goldenImage        GoldenImage?    @relation(fields: [goldenImageId], references: [id])
  department         Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  machines           Machine[]

  @@index([departmentId])
  @@index([templateId])
  @@index([goldenImageId])
}

// Join: which apps every VM from this blueprint gets.
model MachineTemplateApplication {
  templateId    String
  applicationId String
  // Override parameters (same shape as MachineApplication.parameters).
  // Merged with the Application's default parameters at VM creation.
  parameters    Json?
  createdAt     DateTime        @default(now())
  template      MachineTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  application   Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@id([templateId, applicationId])
  @@index([templateId])
  @@index([applicationId])
}

// Join: which FIRST_BOOT scripts every VM runs.
model MachineTemplateScript {
  templateId  String
  scriptId    String
  // Values to interpolate into the script — shape matches
  // ScriptExecution.inputValues.
  inputValues Json?
  // Execution order within the blueprint (lower first).
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  template    MachineTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  script      Script          @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@id([templateId, scriptId])
  @@index([templateId])
  @@index([scriptId])
}

// A sealed base disk image used as the backing file for thin clones.
// Separate from MachineTemplate (config blueprint): this entity owns the
// actual on-disk qcow2 at baseDiskPath. Lifecycle: building → draft →
// published → deprecated. Versions form a family tree via parentImageId.
model GoldenImage {
  id               String            @id @default(uuid())
  name             String
  // Canonical OS key: 'windows-10' | 'windows-11' | 'ubuntu' | 'fedora'.
  osType           String
  osVersion        String?
  // Absolute path to the sealed qcow2 on the host. Read-only in practice:
  // modifying it invalidates every clone that backs off it.
  baseDiskPath     String
  sizeBytes        BigInt            @default(0)
  // 'building' | 'draft' | 'published' | 'deprecated' | 'failed'
  status           String            @default("building")
  version          Int               @default(1)
  // Previous version in the same family (null for the first version).
  parentImageId    String?
  parent           GoldenImage?      @relation("GoldenImageVersions", fields: [parentImageId], references: [id])
  children         GoldenImage[]     @relation("GoldenImageVersions")
  // 'automated' (from blueprint) | 'manual-capture' (from existing VM).
  sourceType       String
  sourceMachineId  String?
  sourceTemplateId String?
  // Snapshot of the hardening toggles applied at build time, for audit
  // and reproducibility. Shape is free-form JSON (e.g. { telemetry: true,
  // cortana: true, bloatware: 'curated', defender: 'keep' }).
  hardeningApplied Json?
  notes            String?
  createdById      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  sealedAt         DateTime?
  deprecatedAt     DateTime?
  templates        MachineTemplate[]
  pools            Pool[]

  @@index([status])
  @@index([osType, status])
  @@index([parentImageId])
}

model MachineTemplateCategory {
  id          String            @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  templates   MachineTemplate[]
}

model Application {
  id             String                       @id @default(uuid())
  name           String
  description    String?
  version        String?
  url            String?
  icon           String?
  os             String[]
  installCommand Json
  parameters     Json
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  machines       MachineApplication[]
  templates      MachineTemplateApplication[]
}

model MachineApplication {
  machineId     String
  applicationId String
  parameters    Json
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  application   Application @relation(fields: [applicationId], references: [id])
  machine       Machine     @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@id([machineId, applicationId])
}

model PendingCommand {
  id         String   @id @default(uuid())
  machineId  String
  command    String
  parameters Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  machine    Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@index([machineId])
}

model Notification {
  id        String   @id @default(uuid())
  message   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id                String                 @id @default(uuid())
  name              String
  createdAt         DateTime               @default(now())
  internetSpeed     Int?
  ipSubnet          String?
  updatedAt         DateTime               @updatedAt
  firewallRuleSetId String?                @unique
  firewallRuleSet   FirewallRuleSet?       @relation(fields: [firewallRuleSetId], references: [id], onDelete: SetNull)
  machines          Machine[]
  scriptAssignments DepartmentScript[]
  pools             Pool[]
  memberships       DepartmentMembership[]

  // Network infrastructure fields
  bridgeName     String? // Linux bridge name: "infinibr-{shortId}" (max 15 chars)
  gatewayIP      String? // Gateway IP on bridge: "10.10.100.1"
  dhcpRangeStart String? // DHCP pool start: "10.10.100.10"
  dhcpRangeEnd   String? // DHCP pool end: "10.10.100.254"
  dnsmasqPid     Int? // PID of dnsmasq process for this bridge
  dnsServers     String[] @default(["8.8.8.8", "8.8.4.4", "1.1.1.1"]) // DNS servers for DHCP clients
  ntpServers     String[] @default(["216.239.35.0", "162.159.200.1"]) // NTP servers for DHCP clients (Google: 216.239.35.0, Cloudflare: 162.159.200.1)
  mtu            Int?     @default(1500) // MTU for DHCP clients (default: 1500 for standard Ethernet)

  // Firewall policy configuration
  firewallPolicy        FirewallPolicy @default(BLOCK_ALL)
  firewallDefaultConfig String?        @default("allow_outbound")
  firewallCustomRules   Json?

  @@index([bridgeName])
}

// Explicit, role-bearing membership of a user in a department. This is the
// backbone of department-scoped permissions: a MANAGER can operate the
// department's resources (desktops, pools, scripts) without being a global
// ADMIN, while a MEMBER is simply a recorded participant. Global ADMIN /
// SUPER_ADMIN still bypass these checks.
model DepartmentMembership {
  id           String         @id @default(uuid())
  departmentId String
  userId       String
  role         DepartmentRole @default(MEMBER)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  department   Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@index([userId])
  @@index([departmentId])
}

// Append-only audit trail for authorization changes: role-permission matrix
// edits and department-membership changes. Never updated or deleted by the
// app — it is the record of "who changed access, when, and to what".
model PolicyAuditLog {
  id         String   @id @default(uuid())
  // Null when the actor user was later deleted (FK set null).
  actorId    String?
  // Machine-readable action, e.g. 'role_permission.set', 'department_member.set'.
  action     String
  // What the change targeted: 'role' | 'department' | etc.
  targetType String
  targetId   String?
  // Human-readable one-line description shown in the audit UI.
  summary    String
  // Free-form structured detail (before/after, resource, effect, …).
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation("PolicyAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorId])
}

enum DepartmentRole {
  MEMBER
  MANAGER
}

